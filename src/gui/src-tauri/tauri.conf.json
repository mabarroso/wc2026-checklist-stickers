{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Panini WC 2026",
  "version": "1.0.0",
  "identifier": "com.panini.wc2026.checklist",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "Panini WC 2026 Checklist",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 768,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "opener": {
      "requireLiteralLeadingDot": false
    },
    "fs": {
      "scope": ["**"]
    },
    "dialog": {}
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}