{
  "name": "panini-stickers",
  "version": "1.0.1",
  "description": "CLI tool to track Panini FIFA World Cup 2026 sticker collection",
  "type": "module",
  "bin": {
    "panini-stickers": "./dist/panini-stickers.js"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun run build.mjs",
    "test": "bun test",
    "lint": "echo 'Lint not configured'",
    "typecheck": "tsc --noEmit",
    "gui:web": "cd src/gui && bun run dev",
    "gui:desktop": "cd src/gui && bun run tauri dev"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "conf": "^13.0.0",
    "inquirer": "^9.2.12",
    "pdfkit": "^0.15.0"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@rollup/rollup-linux-x64-gnu": "^4.19.0",
    "@types/inquirer": "^9.0.9",
    "@types/pdfkit": "^0.13.0",
    "esbuild": "^0.28.0",
    "rollup": "^4.19.0",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0"
  }
}